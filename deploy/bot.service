[Unit]
Description=Personal Team Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=%h/personal-team
EnvironmentFile=%h/.env
ExecStart=%h/personal-team/.venv/bin/python bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
